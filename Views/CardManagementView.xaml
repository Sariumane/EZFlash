<UserControl x:Class="EZFlash.Views.CardManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             
             xmlns:vm="clr-namespace:EZFlash.ViewModels"
             xmlns:views="clr-namespace:EZFlash.Views"
             Focusable="True"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <DataTemplate DataType="{x:Type vm:CreateOrEditCardViewModel}">
            <views:CreateOrEditCardView />
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:CardViewModel}">
            <views:CardView/>
        </DataTemplate>

        <Style x:Key="CardManagement.TimerButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="{StaticResource CardManagement.PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardManagement.CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8"
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                Property="Background"
                                Value="#1E293B"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                Property="Opacity"
                                Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardManagement.TimerPillStyle" TargetType="Border">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardManagement.CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CardManagement.TimerTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CardManagement.SecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="Left"
                    Command="{Binding PreviousCardCommand}" />

        <KeyBinding Key="Right"
                    Command="{Binding NextCardCommand}" />

        <KeyBinding Key="Esc"
                    Command="{Binding AbortCommand}"/>
    </UserControl.InputBindings>

    <Grid Background="{StaticResource CardManagement.PageBackgroundBrush}"
      Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="80" />
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0"
               Grid.Column="0"
               Grid.ColumnSpan="3"
               Margin="0,0,0,18">

            <TextBlock DockPanel.Dock="Left"
                       Text="{Binding CurrentDeckName}"
                       d:Text="Dummy Deck"
                       Style="{StaticResource CardManagement.DeckTitleTextStyle}" />

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,12,0">

                    <Button Content="{Binding ReviewTimerButtonText}"
                            Command="{Binding ToggleReviewTimerCommand}"
                            Style="{StaticResource CardManagement.TimerButtonStyle}"
                            Margin="0,0,8,0"/>

                    <Border Style="{StaticResource CardManagement.TimerPillStyle}"
                            Visibility="{Binding ReviewTimerVisibility}">

                        <TextBlock Text="{Binding ReviewTimerText}"
                                   Style="{StaticResource CardManagement.TimerTextStyle}"/>
                    </Border>

                </StackPanel>

                <TextBlock Text="{Binding CardPositionText}"
                           d:Text="Dummy Anzahl"
                           Style="{StaticResource CardManagement.PositionTextStyle}"
                           Margin="0,0,18,0" />

                <Button Content="Neue Karte"
                        Command="{Binding CreateNewCardCommand}"
                        Style="{StaticResource CardManagement.NewButtonStyle}"
                        Margin="0,0,8,0" />

                <Button Content="Bearbeiten"
                        Command="{Binding EditCurrentCardCommand}"
                        Style="{StaticResource CardManagement.EditButtonStyle}"
                        Margin="0,0,8,0" />

                <Button Content="Löschen"
                        Command="{Binding DeleteCurrentCardCommand}"
                        Style="{StaticResource CardManagement.DeleteButtonStyle}" />
            </StackPanel>
        </DockPanel>

        <!-- Links -->
        <Button Grid.Row="1"
                Grid.Column="0"
                Command="{Binding PreviousCardCommand}"
                Style="{StaticResource CardManagement.ArrowNavigationButtonStyle}"
                Margin="0,0,12,0">

            <TextBlock Text="‹"
                       FontSize="54"
                       FontWeight="Light" />
        </Button>

        <!-- Rechts -->
        <Button Grid.Row="1"
                Grid.Column="2"
                Command="{Binding NextCardCommand}"
                Style="{StaticResource CardManagement.ArrowNavigationButtonStyle}"
                Margin="12,0,0,0">

            <TextBlock Text="›"
                       FontSize="54"
                       FontWeight="Light" />    
        </Button>

        <ContentControl Grid.Row="1"
                        Grid.Column="1"
                        Content="{Binding CurrentEditorViewModel}"
                        Margin="0,24,0,0" /> 
    </Grid>
</UserControl>
