<UserControl x:Class="EZFlash.Views.CardManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             
             xmlns:vm="clr-namespace:EZFlash.ViewModels"
             xmlns:views="clr-namespace:EZFlash.Views"
             Focusable="True">

    <UserControl.Resources>
        <DataTemplate DataType="{x:Type vm:CreateOrEditCardViewModel}">
            <views:CreateOrEditCardView />
        </DataTemplate>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="Left"
                    Command="{Binding PreviousCardCommand}" />

        <KeyBinding Key="Right"
                    Command="{Binding NextCardCommand}" />
    </UserControl.InputBindings>

    <Grid Background="{StaticResource CardManagement.PageBackgroundBrush}"
      Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="80" />
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0"
               Grid.Column="0"
               Grid.ColumnSpan="3"
               Margin="0,0,0,18">

            <TextBlock DockPanel.Dock="Left"
                       Text="{Binding CurrentDeckName}"
                       d:Text="Dummy Deck"
                       Style="{StaticResource CardManagement.DeckTitleTextStyle}" />

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <TextBlock Text="{Binding CardPositionText}"
                           d:Text="Dummy Anzahl"
                           Style="{StaticResource CardManagement.PositionTextStyle}"
                           Margin="0,0,18,0" />

                <Button Content="Neue Karte"
                        Command="{Binding CreateNewCardCommand}"
                        Style="{StaticResource CardManagement.PrimaryActionButtonStyle}"
                        Margin="0,0,8,0" />

                <Button Content="Bearbeiten"
                        Command="{Binding EditCurrentCardCommand}"
                        Style="{StaticResource CardManagement.ActionButtonStyle}"
                        Margin="0,0,8,0" />

                <Button Content="Löschen"
                        Command="{Binding DeleteCurrentCardCommand}"
                        Style="{StaticResource CardManagement.DangerActionButtonStyle}" />
            </StackPanel>
        </DockPanel>

        <!-- Links -->
        <Button Grid.Row="1"
                Grid.Column="0"
                Command="{Binding PreviousCardCommand}"
                Style="{StaticResource CardManagement.ArrowNavigationButtonStyle}"
                Margin="0,0,12,0">

            <TextBlock Text="‹"
                       FontSize="54"
                       FontWeight="Light" />
        </Button>

        <!-- Karte -->
        <Border Grid.Row="1"
                Grid.Column="1"
                Padding="34"
                CornerRadius="14"
                Background="{StaticResource CardManagement.CardBackgroundBrush}"
                BorderBrush="{StaticResource CardManagement.CardBorderBrush}"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            VerticalAlignment="Center">

                    <TextBlock Text="Frage"
                               Style="{StaticResource CardManagement.CardLabelTextStyle}" />

                    <TextBlock Text="{Binding CurrentCard.Question}"
                               d:Text="Dummy Frage"
                               Style="{StaticResource CardManagement.QuestionTextStyle}" />
                </StackPanel>

                <Border Grid.Row="1"
                        Height="1"
                        Background="{StaticResource CardManagement.CardBorderBrush}"
                        Margin="0,30" />

                <StackPanel Grid.Row="2"
                            VerticalAlignment="Center">

                    <TextBlock Text="Antwort"
                               Style="{StaticResource CardManagement.CardLabelTextStyle}" />

                    <TextBlock Text="{Binding CurrentCard.Answer}"
                               d:Text="Dummy Antwort"
                               Style="{StaticResource CardManagement.AnswerTextStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Rechts -->
        <Button Grid.Row="1"
                Grid.Column="2"
                Command="{Binding NextCardCommand}"
                Style="{StaticResource CardManagement.ArrowNavigationButtonStyle}"
                Margin="12,0,0,0">

            <TextBlock Text="›"
                       FontSize="54"
                       FontWeight="Light" />    
        </Button>

        <ContentControl Grid.Row="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Content="{Binding CurrentEditorViewModel}"
                        Margin="0,24,0,0" /> 
    </Grid>
</UserControl>
