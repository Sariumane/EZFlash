<UserControl x:Class="EZFlash.Views.LearningResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>

        <SolidColorBrush x:Key="Result.PageBackgroundBrush" Color="#0B1222" />
        <SolidColorBrush x:Key="Result.CardBackgroundBrush" Color="#111A2E" />
        <SolidColorBrush x:Key="Result.CardBorderBrush" Color="#334155" />

        <SolidColorBrush x:Key="Result.PrimaryTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="Result.SecondaryTextBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="Result.MutedTextBrush" Color="#64748B" />

        <Style x:Key="ResultButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="Left"
                    Command="{Binding ShowOlderReviewCommand}" />

        <KeyBinding Key="Right"
                    Command="{Binding ShowNewerReviewCommand}" />
    </UserControl.InputBindings>
    
    <Grid Background="{StaticResource Result.PageBackgroundBrush}">

        <Border HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,36,34,0"
                Padding="16,10"
                Background="{StaticResource Result.CardBackgroundBrush}"
                BorderBrush="{StaticResource Result.CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Visibility="{Binding ReviewNavigationVisibility}">

            <TextBlock Text="{Binding ReviewPositionText}"
               Foreground="{StaticResource Result.PrimaryTextBrush}"
               FontSize="16"
               FontWeight="SemiBold"/>
        </Border>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="620">

            <TextBlock Text="{Binding Title}"
                       Foreground="{StaticResource Result.PrimaryTextBrush}"
                       FontSize="32"
                       FontWeight="Bold"
                       TextAlignment="Center" />

            <TextBlock Text="{Binding Subtitle}"
                       Foreground="{StaticResource Result.SecondaryTextBrush}"
                       FontSize="15"
                       TextAlignment="Center"
                       Margin="0,8,0,32" />

            <Border Background="{StaticResource Result.CardBackgroundBrush}"
                    BorderBrush="{StaticResource Result.CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="36">

                <StackPanel>

                    <TextBlock Text="Score"
                               Foreground="{StaticResource Result.MutedTextBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextAlignment="Center" />

                    <TextBlock Text="{Binding ScoreText}"
                               Foreground="{StaticResource Result.PrimaryTextBrush}"
                               FontSize="56"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Margin="0,4,0,28" />

                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Total"
                                       Foreground="{StaticResource Result.MutedTextBrush}"
                                       TextAlignment="Center" />
                            <TextBlock Text="{Binding TotalCards}"
                                       Foreground="{StaticResource Result.PrimaryTextBrush}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       TextAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Again"
                                       Foreground="{StaticResource Result.MutedTextBrush}"
                                       TextAlignment="Center" />
                            <TextBlock Text="{Binding AgainCount}"
                                       Foreground="{StaticResource Result.PrimaryTextBrush}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       TextAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Hard"
                                       Foreground="{StaticResource Result.MutedTextBrush}"
                                       TextAlignment="Center" />
                            <TextBlock Text="{Binding HardCount}"
                                       Foreground="{StaticResource Result.PrimaryTextBrush}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       TextAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="3">
                            <TextBlock Text="Good"
                                       Foreground="{StaticResource Result.MutedTextBrush}"
                                       TextAlignment="Center" />
                            <TextBlock Text="{Binding GoodCount}"
                                       Foreground="{StaticResource Result.PrimaryTextBrush}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       TextAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Easy"
                                       Foreground="{StaticResource Result.MutedTextBrush}"
                                       TextAlignment="Center" />
                            <TextBlock Text="{Binding EasyCount}"
                                       Foreground="{StaticResource Result.PrimaryTextBrush}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,0,0,16"
            Visibility="{Binding ReviewNavigationVisibility}">

                        <Button Content="← Ältere Review"
            Command="{Binding ShowOlderReviewCommand}"
            Style="{StaticResource ResultButtonStyle}"
            Margin="0,0,12,0"/>

                        <Button Content="Neuere Review →"
            Command="{Binding ShowNewerReviewCommand}"
            Style="{StaticResource ResultButtonStyle}"/>

                    </StackPanel>

                    <Button Content="{Binding BackOverviewText}"
                            Command="{Binding BackOverviewCommand}"
                            Style="{StaticResource ResultButtonStyle}"
                            HorizontalAlignment="Center" />

                </StackPanel>

            </Border>

        </StackPanel>

    </Grid>
</UserControl>