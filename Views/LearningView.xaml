<UserControl x:Class="EZFlash.Views.LearningView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True">

    <UserControl.Resources>

        <SolidColorBrush x:Key="Learning.PageBackgroundBrush" Color="#0B1222" />
        <SolidColorBrush x:Key="Learning.CardBackgroundBrush" Color="#111A2E" />
        <SolidColorBrush x:Key="Learning.CardBorderBrush" Color="#334155" />

        <SolidColorBrush x:Key="Learning.PrimaryTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="Learning.SecondaryTextBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="Learning.MutedTextBrush" Color="#64748B" />

        <SolidColorBrush x:Key="Learning.AgainBrush" Color="#EF4444" />
        <SolidColorBrush x:Key="Learning.HardBrush" Color="#F97316" />
        <SolidColorBrush x:Key="Learning.GoodBrush" Color="#22C55E" />
        <SolidColorBrush x:Key="Learning.EasyBrush" Color="#3B82F6" />

        <Style x:Key="LearningRatingButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="LearningPrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="180" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

    </UserControl.Resources>

    <Grid Background="{StaticResource Learning.PageBackgroundBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0"
              Margin="32,28,32,16">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding Title}"
                           Foreground="{StaticResource Learning.PrimaryTextBrush}"
                           FontSize="28"
                           FontWeight="Bold" />

                <TextBlock Text="{Binding Subtitle}"
                           Foreground="{StaticResource Learning.SecondaryTextBrush}"
                           FontSize="14"
                           Margin="0,6,0,0" />
            </StackPanel>

            <Border Grid.Column="1"
                    Background="{StaticResource Learning.CardBackgroundBrush}"
                    BorderBrush="{StaticResource Learning.CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="18,10"
                    VerticalAlignment="Center">

                <TextBlock Text="{Binding ProgressText}"
                           Foreground="{StaticResource Learning.PrimaryTextBrush}"
                           FontSize="16"
                           FontWeight="SemiBold" />

            </Border>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1"
              Margin="32">

            <!-- Empty State -->
            <Border Visibility="{Binding EmptyStateVisibility}"
                    Background="{StaticResource Learning.CardBackgroundBrush}"
                    BorderBrush="{StaticResource Learning.CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="520">

                <StackPanel>
                    <TextBlock Text="{Binding EmptyStateText}"
                               Foreground="{StaticResource Learning.PrimaryTextBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Du kannst später wiederkommen oder ein anderes Deck auswählen."
                               Foreground="{StaticResource Learning.SecondaryTextBrush}"
                               FontSize="14"
                               Margin="0,12,0,0"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>

            </Border>

            <!-- Learning Card -->
            <Border Visibility="{Binding CardVisibility}"
                    Background="{StaticResource Learning.CardBackgroundBrush}"
                    BorderBrush="{StaticResource Learning.CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="36"
                    MaxWidth="780"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Question -->
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Frage"
                                   Foreground="{StaticResource Learning.MutedTextBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <TextBlock Text="{Binding Question}"
                                   Foreground="{StaticResource Learning.PrimaryTextBrush}"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,0,0,34" />
                    </StackPanel>

                    <!-- Answer -->
                    <StackPanel Grid.Row="1"
                                Visibility="{Binding AnswerVisibility}">

                        <Border Height="1"
                                Background="{StaticResource Learning.CardBorderBrush}"
                                Margin="0,0,0,28" />

                        <TextBlock Text="Antwort"
                                   Foreground="{StaticResource Learning.MutedTextBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <TextBlock Text="{Binding Answer}"
                                   Foreground="{StaticResource Learning.PrimaryTextBrush}"
                                   FontSize="24"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,0,0,34" />

                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="2"
                                HorizontalAlignment="Center">

                        <Button Content="Antwort anzeigen"
                                Command="{Binding ShowAnswerCommand}"
                                Visibility="{Binding ShowAnswerButtonVisibility}"
                                Style="{StaticResource LearningPrimaryButtonStyle}" />

                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding RatingButtonsVisibility}"
                                    HorizontalAlignment="Center">

                            <Button Content="Again"
                                    Command="{Binding RateAgainCommand}"
                                    Background="{StaticResource Learning.AgainBrush}"
                                    Style="{StaticResource LearningRatingButtonStyle}" />

                            <Button Content="Hard"
                                    Command="{Binding RateHardCommand}"
                                    Background="{StaticResource Learning.HardBrush}"
                                    Style="{StaticResource LearningRatingButtonStyle}" />

                            <Button Content="Good"
                                    Command="{Binding RateGoodCommand}"
                                    Background="{StaticResource Learning.GoodBrush}"
                                    Style="{StaticResource LearningRatingButtonStyle}" />

                            <Button Content="Easy"
                                    Command="{Binding RateEasyCommand}"
                                    Background="{StaticResource Learning.EasyBrush}"
                                    Style="{StaticResource LearningRatingButtonStyle}" />

                        </StackPanel>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>