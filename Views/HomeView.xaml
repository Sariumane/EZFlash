<UserControl x:Class="EZFlash.Views.HomeView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource MainBackgroundBrush}">

    <Grid Background="{StaticResource MainBackgroundBrush}">
        <Border Background="{StaticResource MainBackgroundBrush}"
                BorderBrush="Transparent"
                BorderThickness="0"
                Padding="30"
                MinWidth="500"
                MaxWidth="1200"
                HorizontalAlignment="Center">

            <StackPanel>
                <TextBlock Text="Willkommen bei EZFlash"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           FontSize="32"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="20"/>

                <ListBox ItemsSource="{Binding Library}"
                         BorderThickness="0"
                         Background="Transparent" 
                         Width="700"
                         ItemContainerStyle="{StaticResource DeckListStyle}">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="16"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>