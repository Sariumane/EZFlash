<Window x:Class="EZFlash.Views.RenameDeckDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Height="230"
        Width="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        Background="{StaticResource CardManagement.PageBackgroundBrush}"
        FocusManager.FocusedElement="{Binding ElementName=DeckNameTextBox}"
        Loaded="DeckNameTextBox_Loaded" >

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="64"
                            ResizeBorderThickness="0"
                            GlassFrameThickness="0"
                            CornerRadius="12" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource CardManagement.CardBackgroundBrush}"
            BorderBrush="{StaticResource CardManagement.CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="24">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Deck umbenennen"
                       Foreground="{StaticResource CardManagement.PrimaryTextBrush}"
                       FontSize="20"
                       FontWeight="SemiBold" />

            <TextBox x:Name="DeckNameTextBox"
                     Grid.Row="2"
                     Text="{Binding DeckName, UpdateSourceTrigger=PropertyChanged}"
                     Height="38"
                     Padding="10,0"
                     FontSize="15"
                     VerticalContentAlignment="Center"
                     Foreground="{StaticResource CardManagement.PrimaryTextBrush}"
                     Background="#0F172A"
                     BorderBrush="{StaticResource CardManagement.CardBorderBrush}"
                     BorderThickness="1"
                     CaretBrush="{StaticResource CardManagement.PrimaryTextBrush}" />

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Cancel"
                        Style="{StaticResource CardManagement.EditButtonStyle}"
                        MinWidth="90"
                        Margin="0,0,10,0"
                        Command="{Binding CancelCommand}" />

                <Button Content="Save"
                        Style="{StaticResource CardManagement.NewButtonStyle}"
                        MinWidth="90"
                        IsDefault="True"
                        Command="{Binding SaveCommand}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>