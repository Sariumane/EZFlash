<UserControl x:Class="EZFlash.Views.CardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EZFlash.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Border Grid.Row="1"
        Grid.Column="1"
        Padding="34"
        CornerRadius="14"
        Background="{StaticResource CardManagement.CardBackgroundBrush}"
        BorderBrush="{StaticResource CardManagement.CardBorderBrush}"
        BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                    VerticalAlignment="Center">

                <TextBlock Text="Question" Margin="0, 0, 0, 40"
                       Style="{StaticResource CardManagement.CardLabelTextStyle}" />

                <TextBlock Text="{Binding Question}"
                       d:Text="Sample Question"
                       Style="{StaticResource CardManagement.QuestionTextStyle}" />
            </StackPanel>

            <Border Grid.Row="1"
                Height="1"
                Background="{StaticResource CardManagement.CardBorderBrush}"
                Margin="0,30" />

            <StackPanel Grid.Row="2"
                    VerticalAlignment="Center">

                <TextBlock Text="Answer" Margin="0, 0, 0, 40"
                       Style="{StaticResource CardManagement.CardLabelTextStyle}" />

                <TextBlock Text="{Binding Answer}"
                       d:Text="Sample Answer"
                       Style="{StaticResource CardManagement.AnswerTextStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
