<Window x:Class="WpfMvvmMinimal.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:WpfMvvmMinimal.ViewModels"
        Title="Minimales MVVM-Beispiel"
        Width="420"
        Height="200"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">

    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32">
            <Menu>
                <MenuItem Header="Datei">
                    <MenuItem Header="Beenden" Command="{Binding ExitCommand}" />
                </MenuItem>
            </Menu>
            <Border Background="#FF007ACC"
                Padding="12"
                Margin="0,0,0,16"
                BorderThickness="1"
                CornerRadius="12">
                <TextBlock FontSize="20"
                       FontWeight="Bold"
                       Foreground="GreenYellow"
                       Text="Willkommen zum MVVM-Beispiel!" />
            </Border>
            <TextBlock Margin="0,0,0,8"
                   FontWeight="SemiBold"
                   Text="Dein Name" />

            <TextBox Margin="0,0,0,12"
                 Padding="8"
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

            <Button Width="120"
                Margin="0,0,0,16"
                Padding="8"
                HorizontalAlignment="Left"
                Command="{Binding ShowGreetingCommand}"
                Content="Begrüßen" />

            <TextBlock FontSize="18"
                   Text="{Binding Greeting}" />
        </StackPanel>
    </ScrollViewer>
</Window>
