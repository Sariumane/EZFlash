<Window x:Class="EZFlash.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        
        xmlns:viewModels="clr-namespace:EZFlash.ViewModels"
        xmlns:views="clr-namespace:EZFlash.Views"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}"
        
        Icon="/Assets/EZFlash_icon.ico"
        Title="EZFlash"
        Width="1200"
        Height="800"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <!-- Definine the Views that ViewModels map to -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:CardManagementViewModel}">
            <views:CardManagementView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:LearningViewModel}">
            <views:LearningView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:LearningResultViewModel}">
            <views:LearningResultView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ReviewLogViewModel}">
            <views:ReviewLogView/>
        </DataTemplate>
    </Window.Resources>

    <!-- Layout -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Style="{StaticResource SidebarStyle}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                    Content="Home"
                    Style="{StaticResource SidebarButtonStyle}"
                    Command="{Binding ShowHomeViewCommand}"/>

            <Border Grid.Row="1" Background="{StaticResource DividerBrush}"/>

            <Button Grid.Row="2"
                    Content="Settings"
                    Style="{StaticResource SidebarButtonStyle}"
                    Command="{Binding ShowSettingsViewCommand}"/>

            <Border Grid.Row="3" Background="{StaticResource DividerBrush}"/>

            <Button Grid.Row="4"
                    Content="Card Management"
                    Style="{StaticResource SidebarButtonStyle}"
                    Command="{Binding ShowCardManagementViewCommand}"/>    

            <Border Grid.Row="5" Background="{StaticResource DividerBrush}"/>

            <Button Grid.Row="6"
                    Content="Stats"
                    Style="{StaticResource SidebarButtonStyle}"
                    Command="{Binding ShowReviewLogViewCommand}"/>
        </Grid>

        <!-- Separator -->
        <Grid Grid.Column="1" Background="{StaticResource DividerBrush}"/>
        
            <!-- Main Content -->
        <Grid Grid.Column="2" Background="{StaticResource MainBackgroundBrush}">
            <ContentControl 
                x:Name="MainContent"
                Grid.Column="3"
                Background="{StaticResource MainBackgroundBrush}"
                Content="{Binding CurrentViewModel}"/>
        </Grid>
    </Grid>
</Window>
