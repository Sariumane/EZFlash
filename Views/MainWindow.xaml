<Window x:Class="EZFlash.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        
        xmlns:viewModels="clr-namespace:EZFlash.ViewModels"
        xmlns:views="clr-namespace:EZFlash.Views"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}"
        
        Icon="/Assets/EZFlash_icon.ico"
        Title="EZFlash"
        Width="1200"
        Height="800"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <!-- Context for Bindings -->
    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>

    <!-- Layout -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Style="{StaticResource SidebarStyle}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                Content="Home"
                Style="{StaticResource SidebarButtonStyle}"/>

            <Border Grid.Row="1" Background="{StaticResource DividerBrush}"/>

            <Button Grid.Row="2"
                Content="Learn Scheduled"
                Style="{StaticResource SidebarButtonStyle}"/>

            <Border Grid.Row="3" Background="{StaticResource DividerBrush}"/>

            <Button Grid.Row="4"
                Content="Free Learn"
                Style="{StaticResource SidebarButtonStyle}"/>

            <Border Grid.Row="5" Background="{StaticResource DividerBrush}"/>

            <Button Grid.Row="6"
                Content="Stats"
                Style="{StaticResource SidebarButtonStyle}"/>
        </Grid>

        <!-- Separator -->
        <Grid Grid.Column="1" Background="{StaticResource DividerBrush}"/>

        <!-- Main Content -->
        <Grid Grid.Column="2" Background="{StaticResource MainBackgroundBrush}">
            <views:HomeView/>
        </Grid>
    </Grid>
</Window>
